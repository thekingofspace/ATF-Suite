{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "selene: lint src",
      "detail": "Run selene over the src/ tree (default build task).",
      "type": "shell",
      "command": "selene",
      "args": ["--display-style", "quiet", "src"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "selene",
        "source": "selene",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error)\\[(\\w+)\\]:\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    },
    {
      "label": "selene: lint workspace",
      "detail": "Run selene over the entire workspace.",
      "type": "shell",
      "command": "selene",
      "args": ["--display-style", "quiet", "."],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "selene",
        "source": "selene",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error)\\[(\\w+)\\]:\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    }
  ]
}
